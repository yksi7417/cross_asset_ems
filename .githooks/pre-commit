#!/usr/bin/env bash
#
# pre-commit hook — fast checks only. Slow checks (full Gradle build,
# full Cargo build) run in CI per task 0.4.
#
# Install: `git config core.hooksPath .githooks`
# (set up by ./scripts/dev/install-hooks.sh)

set -euo pipefail

FAIL=0

# --- 1. Block accidental large-file commits ---
LARGE=$(git diff --cached --name-only --diff-filter=A \
    | xargs -I{} -r sh -c 'test -f "{}" && find "{}" -size +10M -print' 2>/dev/null)
if [ -n "$LARGE" ]; then
    echo "ERROR: commits would include files larger than 10 MB:"
    echo "$LARGE"
    FAIL=1
fi

# --- 2. Block secrets ---
# Exclude .githooks/ (this file defines the patterns it would otherwise
# self-match) and tests/fixtures with intentional sample secrets.
SECRET_PATTERNS='(AKIA[0-9A-Z]{16}|-----BEGIN (RSA|EC|OPENSSH|DSA|PGP|ENCRYPTED) PRIVATE KEY-----|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36})'
SECRET_CANDIDATES=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -vE '^(\.githooks/|tests/.*/fixtures/|docs/decisions/)' || true)
if [ -n "$SECRET_CANDIDATES" ]; then
    SECRETS=$(echo "$SECRET_CANDIDATES" | xargs --no-run-if-empty git diff --cached -U0 -- \
        | grep -E "^\+" \
        | grep -vE "^\+\+\+" \
        | grep -oE "$SECRET_PATTERNS" || true)
    if [ -n "$SECRETS" ]; then
        echo "ERROR: secret-like patterns detected in staged changes:"
        echo "$SECRETS"
        echo "If this is a false positive, commit with --no-verify after review."
        FAIL=1
    fi
fi

# --- 3. Trailing whitespace + tabs/CRLF in text files ---
WS=$(git diff --cached --check) || {
    echo "$WS"
    FAIL=1
}

# --- 4. YAML lint (FSM definitions, Compose files, CI configs) ---
YAML_FILES=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.ya?ml$' || true)
if [ -n "$YAML_FILES" ] && command -v yamllint >/dev/null 2>&1; then
    echo "$YAML_FILES" | xargs yamllint -d "{rules: {line-length: {max: 200}, indentation: {spaces: 2}}}" || FAIL=1
fi
# When any FSM YAML is staged, lint the entire schemas/fsm/ directory —
# matches CI scope so pre-existing violations in adjacent files are caught.
FSM_YAML_STAGED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^schemas/fsm/.*\.ya?ml$' || true)
if [ -n "$FSM_YAML_STAGED" ] && command -v yamllint >/dev/null 2>&1; then
    yamllint -d "{rules: {line-length: {max: 200}, indentation: {spaces: 2}}}" schemas/fsm/ || FAIL=1
fi

# --- 5. Markdown lint (vault notes) ---
MD_FILES=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.md$' || true)
if [ -n "$MD_FILES" ] && command -v markdownlint >/dev/null 2>&1; then
    echo "$MD_FILES" | xargs --no-run-if-empty markdownlint --config .markdownlint.jsonc \
        || FAIL=1
fi

# --- 6. Shell script lint ---
SHELL_FILES=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.(sh|bash)$' || true)
if [ -n "$SHELL_FILES" ] && command -v shellcheck >/dev/null 2>&1; then
    echo "$SHELL_FILES" | xargs shellcheck || FAIL=1
fi

# --- 7. Spotless Java formatting (auto-apply + re-stage) ---
# Derives the Gradle task from the file path: java/ems-foo/... → :ems-foo:spotlessApply
# Runs only the modules that have staged Java files; no-op (~200ms) when already formatted.
# Auto-applies and re-stages so the commit always lands clean.
JAVA_STAGED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep '^java/.*\.java$' \
    | grep -v '/generated/' || true)
if [ -n "$JAVA_STAGED" ]; then
    SPOTLESS_TASKS=$(echo "$JAVA_STAGED" \
        | sed 's|^java/\([^/]*\)/.*|:\1:spotlessApply|' \
        | sort -u \
        | tr '\n' ' ')
    # shellcheck disable=SC2086
    if ! ./gradlew $SPOTLESS_TASKS --quiet 2>&1; then
        echo "ERROR: Spotless failed. Fix manually or run: ./gradlew spotlessApply"
        FAIL=1
    else
        # Re-add the staged files so any reformatting is included in the commit.
        # Only touches files that were already staged — does not pull in unstaged changes.
        echo "$JAVA_STAGED" | xargs git add
    fi
fi

# --- 8. JaCoCo coverage gate (60% line / 50% branch) ---
# Runs only when Java source (non-generated, non-test) is staged.
# Fails if a module has src/main but no src/test (enforces tests-in-same-commit).
# Gate is NOT wired into :check so CI is unaffected; only the pre-commit hook calls it.
# Gradle's up-to-date check makes this fast when tests haven't changed.
JAVA_MAIN_STAGED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep '^java/.*\.java$' \
    | grep '/src/main/' \
    | grep -v '/generated/' || true)
if [ -n "$JAVA_MAIN_STAGED" ]; then
    COVERAGE_MODULES=$(echo "$JAVA_MAIN_STAGED" \
        | sed 's|^java/\([^/]*\)/.*|\1|' \
        | sort -u)
    for MODULE in $COVERAGE_MODULES; do
        if find "java/$MODULE/src/test" -name "*.java" -quit 2>/dev/null | grep -q .; then
            # shellcheck disable=SC2086
            if ! ./gradlew ":$MODULE:test" ":$MODULE:jacocoTestCoverageVerification" --quiet 2>&1; then
                echo "ERROR: :$MODULE coverage gate failed (60% line / 50% branch required)."
                echo "       Run: ./gradlew :$MODULE:test :$MODULE:jacocoTestReport :$MODULE:jacocoTestCoverageVerification"
                FAIL=1
            fi
        else
            echo "WARN: :$MODULE has production code staged but no test sources found."
            echo "      Add tests in the same commit to pass the coverage gate."
            FAIL=1
        fi
    done
fi

if [ $FAIL -ne 0 ]; then
    echo
    echo "pre-commit checks failed. Fix the issues above, or bypass with --no-verify."
    exit 1
fi

exit 0
