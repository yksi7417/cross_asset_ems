#!/usr/bin/env bash
# Pre-commit hook: (1) regenerate FSM Java from YAML, (2) apply spotless formatting.
# Prevents CI failures for both fsm-drift and spotlessCheck.
#
# Install (once per clone):
#   git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# 1. Regenerate FSM Java — fast (<1s), avoids stale-generated CI failures.
if command -v python3 &>/dev/null && [[ -f "$REPO_ROOT/tools/codegen/fsm_codegen.py" ]]; then
  python3 "$REPO_ROOT/tools/codegen/fsm_codegen.py" --java-only >/dev/null
  git add "$REPO_ROOT/java/ems-fsm/src/main/generated/"
fi

# 2. Apply spotless to all staged Java files (google-java-format).
# spotlessApply auto-formats; we then re-stage any files it touched.
cd "$REPO_ROOT"
./gradlew spotlessApply --quiet
# Re-stage any Java files that spotless reformatted.
# grep exits 1 when no .java files changed; the subshell absorbs that so set -e doesn't kill us.
git diff --name-only | { grep '\.java$' || true; } | xargs --no-run-if-empty git add
