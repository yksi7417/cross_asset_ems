    },
    {
      "id": 102,
      "title": "Slow & Summary",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Slow Orders Rate (>1s end-to-end)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "expr": "sum by (asset_class) (rate(ems_order_path_duration_seconds_bucket{le=\"+Inf\"}[5m])) - sum by (asset_class) (rate(ems_order_path_duration_seconds_bucket{le=\"1\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{asset_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
