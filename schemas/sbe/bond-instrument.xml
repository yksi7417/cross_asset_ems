<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema
    xmlns:sbe="http://fixprotocol.io/2016/sbe"
    package="BondInstrument"
    id="0x2002"
    version="0"
    semanticVersion="1.0"
    byteOrder="littleEndian"
    description="SBE 1.0 schema for the BondInstrument template (template_id=0x2002)">

  <types>

    <composite name="MessageHeader" description="Standard SBE message header">
      <type name="blockLength" primitiveType="uint16"/>
      <type name="templateId"  primitiveType="uint16"/>
      <type name="schemaId"    primitiveType="uint16"/>
      <type name="version"     primitiveType="uint16"/>
    </composite>

    <!--
      InstrumentCore — fixed at offset 0 of every BondInstrument message.
      MUST match the InstrumentCore in every other Instrument template
      (equity-instrument.xml, fx-*, cds-*, etc.) byte-for-byte for the
      first 315 bytes. See 80_architecture/arch-security-master.md
      lines 100-132 for the full spec.
    -->
    <composite name="InstrumentCore" description="Fixed-offset core reference data block (315 bytes) carried at the start of every BondInstrument message">
      <type name="figi"                id="1"  primitiveType="char"  length="12"  offset="0"/>
      <type name="internalIid"         id="2"  primitiveType="char"  length="20"  offset="12"/>
      <type name="compositeFigi"       id="3"  presence="optional"   primitiveType="char"  length="12"  offset="32"/>
      <type name="shareClassFigi"      id="4"  presence="optional"   primitiveType="char"  length="12"  offset="44"/>
      <type name="assetClass"          id="5"  nullValue="255"       primitiveType="uint8"  offset="56"/>
      <type name="instrumentType"      id="6"  nullValue="255"       primitiveType="uint8"  offset="57"/>
      <type name="displayName"         id="7"                       primitiveType="char"  length="64"  offset="58"/>
      <type name="legalName"           id="8"                       primitiveType="char"  length="128" offset="122"/>
      <type name="issuerLei"           id="9"  presence="optional"   primitiveType="char"  length="20"  offset="250"/>
      <type name="currency"            id="10" nullValue="65535"      primitiveType="uint16" offset="270"/>
      <type name="countryOfIssue"      id="11"                       primitiveType="char"  length="2"   offset="272"/>
      <type name="countryOfListing"    id="12" presence="optional"   primitiveType="char"  length="2"   offset="274"/>
      <type name="fungibility"         id="13" nullValue="255"       primitiveType="uint8"  offset="276"/>
      <type name="settlementConvention" id="14" nullValue="255"      primitiveType="uint8"  offset="277"/>
      <type name="effectiveDate"       id="15"                       primitiveType="uint64" offset="278"/>
      <type name="expiryDate"          id="16" presence="optional"   primitiveType="uint64" offset="286"/>
      <type name="status"              id="17" nullValue="255"       primitiveType="uint8"  offset="294"/>
      <type name="createdAt"           id="18"                       primitiveType="uint64" offset="295"/>
      <type name="updatedAt"           id="19"                       primitiveType="uint64" offset="303"/>
      <type name="version"             id="20"                       primitiveType="uint32" offset="311"/>
    </composite>

    <enum name="AssetClass" encodingType="uint8">
      <validValue name="Unset">0</validValue>
      <validValue name="DEBT">5</validValue>
    </enum>

    <enum name="InstrumentType" encodingType="uint8">
      <validValue name="Unset">0</validValue>
      <validValue name="TREASURY">1</validValue>
      <validValue name="CORPORATE_SENIOR">2</validValue>
      <validValue name="CORPORATE_SUBORDINATED">3</validValue>
      <validValue name="MUNICIPAL">4</validValue>
      <validValue name="AGENCY">5</validValue>
      <validValue name="SUPRANATIONAL">6</validValue>
      <validValue name="COVERED">7</validValue>
      <validValue name="MBS_PASS_THROUGH">8</validValue>
      <validValue name="MBS_COVERED">9</validValue>
      <validValue name="ABS">10</validValue>
      <validValue name="CONVERTIBLE">11</validValue>
      <validValue name="INDEX_LINKED">12</validValue>
      <validValue name="ZERO_COUPON">13</validValue>
      <validValue name="MTA">14</validValue>
    </enum>

    <enum name="Status" encodingType="uint8">
      <validValue name="Unset">0</validValue>
      <validValue name="ACTIVE">1</validValue>
      <validValue name="SUPERSEDED">2</validValue>
      <validValue name="RETIRED">3</validValue>
      <validValue name="DRAFT">4</validValue>
    </enum>

    <enum name="Fungibility" encodingType="uint8">
      <validValue name="FUNGIBLE">1</validValue>
      <validValue name="NON_FUNGIBLE">2</validValue>
      <validValue name="TBA_LIKE">3</validValue>
    </enum>

    <enum name="SettlementConvention" encodingType="uint8">
      <validValue name="Unset">0</validValue>
      <validValue name="T_PLUS_0">1</validValue>
      <validValue name="T_PLUS_1">2</validValue>
      <validValue name="T_PLUS_2">3</validValue>
      <validValue name="T_PLUS_3">4</validValue>
      <validValue name="TBA_MONTHLY">5</validValue>
      <validValue name="PER_CCP">6</validValue>
    </enum>

    <type name="varStringEncoding" primitiveType="char"/>

    <composite name="Currency" description="ISO 4217 currency code as uint16">
      <type name="code" primitiveType="uint16"/>
    </composite>

    <enum name="DayCountConvention" encodingType="uint8">
      <validValue name="Unset">0</validValue>
      <validValue name="ACT_360">1</validValue>
      <validValue name="ACT_365_FIXED">2</validValue>
      <validValue name="ACT_ACT_ISDA">3</validValue>
      <validValue name="ACT_ACT_ICMA">4</validValue>
      <validValue name="THIRTY_360">5</validValue>
      <validValue name="THIRTY_360_BOND">6</validValue>
      <validValue name="THIRTY_E_360_ISDA">7</validValue>
      <validValue name="THIRTY_E_360_EUROBOND">8</validValue>
      <validValue name="THIRTY_E_360_ISMA">9</validValue>
      <validValue name="THIRTY_360_ISDA">10</validValue>
      <validValue name="ACT_365_ACTUAL">11</validValue>
      <validValue name="ACT_ACT_AFB">12</validValue>
      <validValue name="ACT_ACT_ISMA">13</validValue>
    </enum>

    <enum name="CouponFrequency" encodingType="uint8">
      <validValue name="ZERO">0</validValue>
      <validValue name="ANNUAL">1</validValue>
      <validValue name="SEMI_ANNUAL">2</validValue>
      <validValue name="QUARTERLY">4</validValue>
      <validValue name="MONTHLY">12</validValue>
      <validValue name="IRREGULAR">99</validValue>
    </enum>

    <enum name="Seniority" encodingType="uint8">
      <validValue name="Unset">0</validValue>
      <validValue name="SENIOR_SECURED">1</validValue>
      <validValue name="SENIOR_UNSECURED">2</validValue>
      <validValue name="SUBORDINATED">3</validValue>
      <validValue name="JUNIOR_SUBORDINATED">4</validValue>
      <validValue name="MEZZANINE">5</validValue>
    </enum>

  </types>

  <sbe:message name="BondInstrument" id="0x2002" description="Bond instrument reference-data message">
    <sbe:header>MessageHeader</sbe:header>
    <field name="instrumentCore" id="1" type="InstrumentCore" offset="0"/>
    <group name="debtAttributes" id="2" type="DebtAttributes" blockLength="200" dimensionType="groupSizeEncoding"/>
  </sbe:message>

  <group name="DebtAttributes" id="100" description="Bond debt attributes (200-byte element block)">
    <field name="couponRateMantissa"      id="1"  type="int64"             offset="0"/>
    <field name="couponRateExponent"      id="2"  type="int8"              offset="8"/>
    <field name="couponFrequency"         id="3"  type="CouponFrequency"   offset="9"/>
    <field name="dayCountConvention"      id="4"  type="DayCountConvention" offset="10"/>
    <field name="faceValue"               id="5"  type="uint64"            offset="11"/>
    <field name="issueDate"               id="6"  type="uint64"            offset="19"/>
    <field name="maturityDate"            id="7"  type="uint64"            offset="27"/>
    <field name="isCallable"              id="8"  type="uint8"             offset="35"/>
    <field name="isPutable"               id="9"  type="uint8"             offset="36"/>
    <field name="isSinkable"              id="10" type="uint8"             offset="37"/>
    <field name="issuerLei"               id="11" type="char"  length="20"  offset="38"/>
    <field name="seniority"               id="12" type="Seniority"         offset="58"/>
    <field name="indentureCusip"          id="13" type="char"  length="9"   offset="59" presence="optional"/>
    <field name="couponPaymentDatesCount" id="14" type="uint8"             offset="68"/>
    <field name="couponPaymentDates"      id="15" type="uint64" length="20" offset="69"/>
  </group>

</sbe:messageSchema>
