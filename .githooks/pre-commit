#!/usr/bin/env bash
# Pre-commit hook: regenerate FSM Java files from YAML sources.
# Prevents CI "fsm drift" failures by keeping generated/ in sync at commit time.
#
# Install (once per clone):
#   git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Always regenerate — it's fast (<1s) and avoids stale-generated CI failures.
if command -v python3 &>/dev/null && [[ -f "$REPO_ROOT/tools/codegen/fsm_codegen.py" ]]; then
  python3 "$REPO_ROOT/tools/codegen/fsm_codegen.py" --java-only >/dev/null
  # Stage any regenerated files so they're included in this commit.
  git add "$REPO_ROOT/java/ems-fsm/src/main/generated/"
fi
