{
  "uid": "ems-per-asset-latency",
  "title": "EMS Per-Asset Latency",
  "tags": [
    "ems",
    "latency"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "Order Path by Asset Class",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "P99 Stage Latency by Asset Class",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (asset_class, le) (rate(ems_stage_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{asset_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "P99 Route\u2192Venue-Ack by Asset Class",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (asset_class, le) (rate(ems_route_ack_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{asset_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "P99 Fill Latency by Asset Class",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (asset_class, le) (rate(ems_fill_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{asset_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Latency Heatmap (all asset classes)",
      "type": "heatmap",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(ems_order_path_duration_seconds_bucket[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Top 10 Slowest Instruments (p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.99, sum by (figi, le) (rate(ems_order_path_duration_seconds_bucket[5m]))))",
          "refId": "A",
          "legendFormat": "{{figi}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 101,
      "title": "Quote-Driven Workflows",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "RFQ Dealer Response Time (p50/p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ems_rfq_response_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ems_rfq_response_duration_seconds_bucket[5m])))",
