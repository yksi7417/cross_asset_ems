# Obsidian vault hygiene (kept from prior state — see USAGE.md §6)
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json
.trash/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Java / Gradle
.gradle/
build/
out/
**/build/
*.class
*.jar
# The Gradle wrapper jar IS committed (Gradle's recommended practice) so fresh
# clones and CI work without bootstrapping. Its checksum is verified in CI by
# gradle/actions/wrapper-validation.
!gradle/wrapper/gradle-wrapper.jar
*.war
hs_err_pid*

# C++ / CMake
build/
CMakeCache.txt
CMakeFiles/

# Python (tools/, scripts/)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/

# Generated code — committed where noted; ignored by code-search tooling otherwise.
**/src/main/generated/
**/src/generated/
# FSM codegen output is committed so reviewers can diff it and CI stays hermetic.
!java/ems-fsm/src/main/generated/

# Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
*.log
logs/

# Editor temp
*.tmp
*.swp
*.swo

# local secrets
open-router.key

# Node / UI builds
node_modules/
ui/*/dist/

# Playwright run artifacts (traces, last-run state)
ui/*/test-results/
ui/*/playwright-report/
