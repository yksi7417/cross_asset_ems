{
  "uid": "ems-business-overview",
  "title": "EMS Business Overview (Trading)",
  "tags": [
    "ems",
    "business"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "Order Flow",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Orders Staged / Routed / Filled (rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(rate(ems_orders_staged_total[5m]))",
          "refId": "A",
          "legendFormat": "staged"
        },
        {
          "expr": "sum(rate(ems_orders_routed_total[5m]))",
          "refId": "B",
          "legendFormat": "routed"
        },
        {
          "expr": "sum(rate(ems_orders_filled_total[5m]))",
          "refId": "C",
          "legendFormat": "filled"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Fill Ratio (filled / routed, 1h)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(ems_orders_filled_total[1h])) / sum(increase(ems_orders_routed_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Notional Traded (USD, 1h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(ems_fills_notional_usd_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Active Trader Sessions",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(ems_sessions_active)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Kill Switch Engaged",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "expr": "max(ems_kill_switch_engaged)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 101,
      "title": "Quality & Controls",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "Rejects by Catalog Code (top 10)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "topk(10, sum by (code) (rate(ems_rejects_total[15m])))",
          "refId": "A",
          "legendFormat": "{{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Compliance Blocks (fat-finger / lists / rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum by (rule) (rate(ems_compliance_blocks_total[15m]))",
          "refId": "A",
          "legendFormat": "{{rule}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "RFQ: Requested / Executed / Faded",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum(rate(ems_rfq_requested_total[15m]))",
          "refId": "A",
          "legendFormat": "requested"
        },
        {
          "expr": "sum(rate(ems_rfq_executed_total[15m]))",
          "refId": "B",
          "legendFormat": "executed"
        },
        {
          "expr": "sum(rate(ems_rfq_faded_total[15m]))",
          "refId": "C",
          "legendFormat": "faded"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 102,
      "title": "Distribution & Health",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Fills by Venue (1h)",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (venue) (increase(ems_fills_total[1h]))",
          "refId": "A",
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Fills by Asset Class (1h)",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (asset_class) (increase(ems_fills_total[1h]))",
          "refId": "A",
          "legendFormat": "{{asset_class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "WS Stream Lag (max event age, per topic)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 19
      },
      "targets": [
        {
          "expr": "max by (topic) (ems_stream_lag_seconds)",
          "refId": "A",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "Reg Reports: Acked vs Nacked",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "expr": "sum by (regulator) (rate(ems_regreports_acked_total[15m]))",
          "refId": "A",
          "legendFormat": "{{regulator}} acked"
        },
        {
          "expr": "sum by (regulator) (rate(ems_regreports_nacked_total[15m]))",
          "refId": "B",
          "legendFormat": "{{regulator}} nacked"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ]
}