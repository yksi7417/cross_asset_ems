{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-asset latency observability: tail latency, slow request rates, and distribution heatmaps grouped by asset.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": 2,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Top 10 Slowest Assets (p99)",
      "description": "Assets ranked by p99 request latency in the selected time range.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "rps"},
            "properties": [
              {"id": "unit", "value": "reqps"},
              {"id": "custom.cellOptions", "value": {"type": "auto"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "error_rate"},
            "properties": [
              {"id": "unit", "value": "percentunit"},
              {"id": "custom.cellOptions", "value": {"type": "gauge", "mode": "gradient"}}
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"displayName": "p99", "desc": true}]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(10, histogram_quantile(0.99, sum by (asset_id, le) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m]))))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{asset_id}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(10, sum by (asset_id) (rate(asset_requests_total{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "rps",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(10, sum by (asset_id) (rate(asset_requests_total{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\",status=~\"5..\"}[5m])) / clamp_min(sum by (asset_id) (rate(asset_requests_total{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m])), 1))",
          "format": "table",
          "instant": true,
          "legendFormat": "error_rate",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "type": "heatmap",
      "title": "Latency Heatmap (all assets)",
      "description": "Distribution of request latencies binned by latency bucket over time.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 9},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "scale": "linear"
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "cellValues": {"decimals": 0},
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "filterValues": {"le": 1e-9},
        "legend": {"show": true},
        "rowsFrame": {"layout": "auto"},
        "tooltip": {"show": true, "yHistogram": false},
        "yAxis": {"axisPlacement": "left", "reverse": false, "unit": "s"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (le) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P99 Latency by Asset",
      "description": "Per-asset p99 latency trend over time.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 9},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (asset_id, le) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{asset_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "P99 Latency Distribution (current)",
      "description": "Bar gauge of latest p99 latency by asset, ordered and color-graded.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 19},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.25},
              {"color": "orange", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(20, histogram_quantile(0.99, sum by (asset_id, le) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m]))))",
          "legendFormat": "{{asset_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Slow Request Rate (>1s)",
      "description": "Rate of requests whose latency exceeds 1 second per asset.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 19},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["mean", "max", "sum"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (asset_id) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\",le=\"1.0\"}[5m])) - sum by (asset_id) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\",le=\"0.5\"}[5m]))",
          "legendFormat": "{{asset_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Per-Asset Latency Summary",
      "description": "Aggregated p50 / p95 / p99 latency, request rate, and error rate per asset.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 28},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "/.*_per_second|.*_rps/"},
            "properties": [
              {"id": "unit", "value": "reqps"}
            ]
          },
          {
            "matcher": {"id": "byRegexp", "options": "/.*_ratio|.*_rate/"},
            "properties": [
              {"id": "unit", "value": "percentunit"}
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"displayName": "p99", "desc": true}]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by (asset_id, asset_type, le) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (asset_id, asset_type, le) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (asset_id, asset_type, le) (rate(asset_request_duration_seconds_bucket{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (asset_id) (rate(asset_requests_total{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "rps",
          "refId": "D"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (asset_id) (rate(asset_requests_total{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\",status=~\"5..\"}[5m])) / clamp_min(sum by (asset_id) (rate(asset_requests_total{asset_id=~\"$asset_id\",asset_type=~\"$asset_type\",environment=~\"$environment\"}[5m])), 1)",
          "format": "table",
          "instant": true,
          "legendFormat": "error_rate",
          "refId": "E"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["observability", "latency", "per-asset", "performance"],
