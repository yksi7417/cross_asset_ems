<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema
    xmlns:sbe="http://fixprotocol.io/2016/sbe"
    xmlns:ns0="http://example.com/sbe/equity"
    package="EquityInstrument"
    id="1"
    version="0"
    semanticVersion="1.0"
    description="SBE 1.0 schema for the EquityInstrument template (template_id=0x2001)">

  <types>

    <composite name="MessageHeader" description="Standard SBE message header">
      <type name="blockLength" primitiveType="uint16"/>
      <type name="templateId"  primitiveType="uint16"/>
      <type name="schemaId"    primitiveType="uint16"/>
      <type name="version"     primitiveType="uint16"/>
    </composite>

    <type name="varStringEncoding" primitiveType="char"/>

    <enum name="AssetClass" encodingType="uint8">
      <validValue name="EQUITY">2</validValue>
    </enum>

    <enum name="InstrumentType" encodingType="uint8">
      <validValue name="COMMON_STOCK">1</validValue>
      <validValue name="PREFERRED">2</validValue>
      <validValue name="ADR">3</validValue>
      <validValue name="GDR">4</validValue>
      <validValue name="ETF">5</validValue>
      <validValue name="REIT">6</validValue>
      <validValue name="RIGHT">7</validValue>
      <validValue name="WARRANT">8</validValue>
      <validValue name="UNIT">9</validValue>
    </enum>

    <enum name="VotingRights" encodingType="uint8">
      <validValue name="ONE_VOTE">1</validValue>
      <validValue name="NONE">2</validValue>
      <validValue name="MULTIPLE">3</validValue>
      <validValue name="RESTRICTED">4</validValue>
    </enum>

    <enum name="Fungibility" encodingType="uint8">
      <validValue name="FUNGIBLE">1</validValue>
      <validValue name="NON_FUNGIBLE">2</validValue>
      <validValue name="TBA_LIKE">3</validValue>
    </enum>

    <enum name="SettlementConvention" encodingType="uint8">
      <validValue name="T_PLUS_0">1</validValue>
      <validValue name="T_PLUS_1">2</validValue>
      <validValue name="T_PLUS_2">3</validValue>
      <validValue name="T_PLUS_3">4</validValue>
    </enum>

    <enum name="Status" encodingType="uint8">
      <validValue name="ACTIVE">1</validValue>
      <validValue name="SUPERSEDED">2</validValue>
      <validValue name="RETIRED">3</validValue>
      <validValue name="DRAFT">4</validValue>
    </enum>

  </types>

  <composite name="InstrumentCore" description="Fixed-offset core reference data block (315 bytes) carried at the start of every EquityInstrument message">
    <type name="figi"                id="1"  primitiveType="char"  length="12"  offset="0"/>
    <type name="internalIid"         id="2"  primitiveType="char"  length="20"  offset="12"/>
    <type name="compositeFigi"       id="3"  presence="optional"   primitiveType="char"  length="12"  offset="32"/>
    <type name="shareClassFigi"      id="4"  presence="optional"   primitiveType="char"  length="12"  offset="44"/>
    <type name="assetClass"          id="5"  nullValue="255"       primitiveType="uint8"  offset="56"/>
    <type name="instrumentType"      id="6"  nullValue="255"       primitiveType="uint8"  offset="57"/>
    <type name="displayName"         id="7"                       primitiveType="char"  length="64"  offset="58"/>
    <type name="legalName"           id="8"                       primitiveType="char"  length="128" offset="122"/>
    <type name="issuerLei"           id="9"  presence="optional"   primitiveType="char"  length="20"  offset="250"/>
    <type name="currency"            id="10" nullValue="65535"      primitiveType="uint16" offset="270"/>
    <type name="countryOfIssue"      id="11"                       primitiveType="char"  length="2"   offset="272"/>
    <type name="countryOfListing"    id="12" presence="optional"   primitiveType="char"  length="2"   offset="274"/>
    <type name="fungibility"         id="13" nullValue="255"       primitiveType="uint8"  offset="276"/>
    <type name="settlementConvention" id="14" nullValue="255"      primitiveType="uint8"  offset="277"/>
    <type name="effectiveDate"       id="15"                       primitiveType="uint64" offset="278"/>
    <type name="expiryDate"          id="16" presence="optional"   primitiveType="uint64" offset="286"/>
    <type name="status"              id="17" nullValue="255"       primitiveType="uint8"  offset="294"/>
    <type name="createdAt"           id="18"                       primitiveType="uint64" offset="295"/>
    <type name="updatedAt"           id="19"                       primitiveType="uint64" offset="303"/>
    <type name="version"             id="20"                       primitiveType="uint32" offset="311"/>
  </composite>

  <group name="EquityAttributes" id="100" description="Equity-specific attributes (78-byte element block)">
    <field name="exchangeMic"      id="1" type="char"   length="4"  offset="0"/>
    <field name="tickerLocal"      id="2" type="char"   length="32" offset="4"/>
    <field name="isPrimaryListing" id="3" type="uint8"             offset="36"/>
    <field name="votingRights"     id="4" type="uint8"             offset="37"/>
    <field name="parValueMantissa" id="5" type="int64"             offset="38"/>
    <field name="parValueExponent" id="6" type="int64"             offset="46"/>
    <field name="shareClassOrdinal" id="7" type="int32"            offset="54"/>
    <field name="lotSize"          id="8" type="uint32"            offset="58"/>
    <field name="tickSizeMantissa" id="9" type="int64"             offset="62"/>
    <field name="tickSizeExponent" id="10" type="int64"            offset="70"/>
  </group>

  <sbe:message name="EquityInstrument" id="0x2001" description="Equity instrument reference-data message">
    <sbe:header>MessageHeader</sbe:header>
    <field name="instrumentCore" id="1" type="InstrumentCore" offset="0"/>
    <group name="equityAttributes" id="2" type="EquityAttributes" blockLength="78" dimensionType="groupSizeEncoding"/>
  </sbe:message>

</sbe:messageSchema>
