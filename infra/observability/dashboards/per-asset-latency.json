      "id": 8,
      "title": "Last-Look Hold Time by Venue (p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (venue, le) (rate(ems_lastlook_hold_duration_seconds_bucket[5m])))",
