        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (venue, le) (rate(ems_esp_click_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": {
