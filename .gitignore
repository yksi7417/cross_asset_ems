# Obsidian vault hygiene (kept from prior state — see USAGE.md §6)
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json
.trash/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Java / Gradle
.gradle/
build/
out/
**/build/
*.class
*.jar
*.war
hs_err_pid*

# Rust / Cargo
target/
Cargo.lock          # workspace lock — re-generated; not committed for library workspaces
**/*.rs.bk

# Python (tools/, scripts/)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/

# Generated code (committed but ignored by code-search tooling)
**/src/main/generated/
**/src/generated/

# Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
*.log
logs/

# Editor temp
*.tmp
*.swp
*.swo
